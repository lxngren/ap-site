  },
  "devDependencies": {
    "@tsconfig/node24": "^24.0.4",
    "@types/node": "^26.1.1",
    "@types/youtube": "^0.3.0",
    "@vitejs/plugin-vue": "^6.0.8",
    "@vue/eslint-config-prettier": "^10.2.0",
    "@vue/eslint-config-typescript": "^14.9.0",
    "@vue/test-utils": "^2.4.11",
    "@vue/tsconfig": "^0.9.1",
    "eslint": "^10.7.0",
    "eslint-plugin-vue": "^10.10.0",
    "happy-dom": "^20.11.1",
    "jiti": "^2.7.0",
    "npm-run-all2": "^9.0.2",
    "prettier": "^3.9.6",
    "typescript": "^5.9.3",
    "vite": "^8.1.5",
